        "when": "focusedView == 'workspaceTodos'"
      },
      {
        "command": "workspace.moveTodoDown",
        "key": "alt+down",
        "mac": "alt+down",
        "when": "focusedView == 'workspaceTodos'"
      },
      {
        "command": "nulab.openSelectedTreeItem",
