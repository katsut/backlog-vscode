        "title": "Set Document Sync Mapping",
        "icon": "$(link)"
      },
      {
        "command": "nulab.documentSync.pull",
        "title": "Pull Documents from Backlog",
        "icon": "$(cloud-download)",
        "category": "Backlog"
      },
      {
        "command": "nulab.documentSync.status",
        "title": "Show Document Sync Status",
        "icon": "$(sync)",
        "category": "Backlog"
