    "menus": {
      "view/title": [
        {
          "command": "nulab.refreshProjects",
          "when": "view == backlogProjects",
          "group": "navigation@1"
        },
        {
          "command": "nulab.searchProjects",
          "when": "view == backlogProjects",
          "group": "navigation@2"
        },
        {
          "command": "nulab.clearProjectSearch",
          "when": "view == backlogProjects",
          "group": "navigation@3"
        },
        {
          "command": "nulab.openSettings",
          "when": "view == backlogProjects",
          "group": "navigation@4"
        },
        {
          "command": "nulab.refreshIssues",
          "when": "view == backlogIssues",
          "group": "navigation@1"
        },
        {
          "command": "nulab.search",
          "when": "view == backlogIssues",
          "group": "navigation@2"
        },
        {
          "command": "nulab.filter",
          "when": "view == backlogIssues",
          "group": "navigation@3"
        },
        {
          "command": "nulab.sort",
          "when": "view == backlogIssues",
          "group": "navigation@4"
        },
        {
          "command": "nulab.clearFilters",
          "when": "view == backlogIssues",
          "group": "navigation@5"
        },
        {
          "command": "nulab.unfocusProject",
          "when": "view == backlogIssues",
          "group": "navigation@6"
        },
        {
          "command": "nulab.refreshWiki",
          "when": "view == backlogWiki",
          "group": "navigation@1"
        },
        {
          "command": "nulab.unfocusProject",
          "when": "view == backlogWiki",
          "group": "navigation@2"
        },
        {
          "command": "nulab.refreshDocuments",
          "when": "view == backlogDocuments",
          "group": "navigation@1"
        },
        {
          "command": "nulab.filterModifiedDocuments",
          "when": "view == backlogDocuments",
          "group": "navigation@2"
        },
        {
          "command": "nulab.unfocusProject",
          "when": "view == backlogDocuments",
          "group": "navigation@3"
        },
        {
          "command": "cacoo.searchDiagrams",
          "when": "view == cacooDiagrams",
          "group": "navigation@0"
        },
        {
          "command": "cacoo.refreshDiagrams",
          "when": "view == cacooDiagrams",
          "group": "navigation@1"
        },
        {
          "command": "cacoo.pull",
          "when": "view == cacooDiagrams",
          "group": "navigation@2"
        },
        {
          "command": "cacoo.setApiKey",
          "when": "view == cacooDiagrams",
          "group": "navigation@3"
        },
        {
          "command": "workspace.refreshMyTasks",
          "when": "view == workspaceMyTasks",
          "group": "navigation@1"
        },
        {
          "command": "workspace.refreshNotifications",
          "when": "view == workspaceNotifications",
          "group": "navigation@1"
        },
        {
          "command": "workspace.toggleNotificationFilter",
          "when": "view == workspaceNotifications",
          "group": "navigation@2"
        },
        {
          "command": "workspace.markAllNotificationsRead",
          "when": "view == workspaceNotifications",
          "group": "navigation@3"
        },
        {
          "command": "workspace.refreshSlack",
          "when": "view == workspaceSlack",
          "group": "navigation@1"
        },
        {
          "command": "workspace.setSlackToken",
          "when": "view == workspaceSlack",
          "group": "navigation@2"
        },
        {
          "command": "workspace.editSlackFavoriteChannels",
          "when": "view == workspaceSlackPost",
          "group": "navigation@1"
        },
        {
          "command": "workspace.refreshSlackSearch",
          "when": "view == workspaceSlackSearch",
          "group": "navigation@1"
        },
        {
          "command": "workspace.editSlackSearchKeywords",
          "when": "view == workspaceSlackSearch",
          "group": "navigation@2"
        },
        {
          "command": "workspace.slackSearchViewGrouped",
          "when": "view == workspaceSlackSearch && nulab.slackSearch.viewMode == flat",
          "group": "navigation@3"
        },
        {
          "command": "workspace.slackSearchViewFlat",
          "when": "view == workspaceSlackSearch && nulab.slackSearch.viewMode == grouped",
          "group": "navigation@3"
        },
        {
          "command": "workspace.refreshDocumentFiles",
          "when": "view == workspaceDocumentFiles",
          "group": "navigation@1"
        },
        {
          "command": "workspace.addTodo",
          "when": "view == workspaceTodos",
          "group": "navigation@1"
        },
        {
          "command": "workspace.clearCompletedTodos",
          "when": "view == workspaceTodos",
          "group": "navigation@2"
        },
        {
          "command": "nulab.google.refreshCalendar",
          "when": "view == workspaceGoogleCalendar",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "nulab.toggleFavorite",
          "when": "view == backlogProjects && viewItem =~ /^(project|favoriteProject)$/",
          "group": "favorites@1"
        },
        {
          "command": "nulab.setDocumentSyncMapping",
          "when": "view == backlogDocuments && viewItem =~ /^(documentFolder|documentWithChildren)$/",
          "group": "sync@1"
        },
        {
          "command": "nulab.documentSync.pull",
          "when": "view == backlogDocuments && viewItem =~ /^(documentFolder|documentWithChildren)$/",
          "group": "sync@2"
        },
        {
          "command": "nulab.documentSync.diff",
          "when": "view == backlogDocuments && viewItem == document",
          "group": "sync@3"
        },
        {
          "command": "nulab.documentSync.copyAndOpen",
          "when": "view == backlogDocuments && viewItem == document",
          "group": "sync@4"
        },
        {
          "command": "cacoo.togglePin",
          "when": "view == cacooDiagrams && viewItem == cacooSheet",
          "group": "pin@1"
        },
        {
          "command": "cacoo.openInBrowser",
          "when": "view == cacooDiagrams && viewItem =~ /^(cacooDiagram|cacooSheet)$/",
          "group": "navigation@1"
        },
        {
          "command": "cacoo.setSyncMapping",
          "when": "view == cacooDiagrams && viewItem == cacooFolder",
          "group": "sync@1"
        },
        {
          "command": "workspace.markNotificationRead",
          "when": "view == workspaceNotifications && viewItem =~ /^notificationUnread/",
          "group": "notification@1"
        },
        {
          "command": "workspace.notificationToTodo",
          "when": "view == workspaceNotifications && viewItem =~ /^notification(Read|Unread)$/",
          "group": "notification@2"
        },
        {
          "command": "workspace.replyToSlack",
          "when": "viewItem == slackMention",
          "group": "slack@1"
        },
        {
          "command": "workspace.openInSlack",
          "when": "viewItem == slackMention",
          "group": "slack@2"
        },
        {
          "command": "workspace.addTodoFromSlack",
          "when": "viewItem == slackMention",
          "group": "slack@3"
        },
        {
          "command": "workspace.openTodoDetail",
          "when": "view == workspaceTodos && viewItem =~ /^todoItem/",
          "group": "inline"
        },
        {
          "command": "workspace.setTodoStatus",
          "when": "view == workspaceTodos && viewItem =~ /^todoItem/",
          "group": "status@1"
        },
        {
          "command": "workspace.editTodoNotes",
          "when": "view == workspaceTodos && viewItem =~ /^todoItem/",
          "group": "status@2"
        },
        {
          "command": "workspace.startClaudeSession",
          "when": "view == workspaceTodos && viewItem =~ /^todoItem.*(backlog|slack)/",
          "group": "action@0"
        },
        {
          "command": "workspace.replyToTodoIssue",
          "when": "view == workspaceTodos && viewItem =~ /^todoItem.*backlog/",
          "group": "action@1"
        },
        {
          "command": "workspace.replyToTodoSlack",
          "when": "view == workspaceTodos && viewItem =~ /^todoItem.*slack/",
          "group": "action@1"
        },
        {
          "command": "workspace.openTodoSource",
          "when": "view == workspaceTodos && viewItem =~ /^todoItem.*(backlog|slack)/",
          "group": "action@2"
        },
        {
          "command": "workspace.editTodo",
          "when": "view == workspaceTodos && viewItem =~ /^todoItem/",
          "group": "todo@1"
        },
        {
          "command": "workspace.deleteTodo",
          "when": "view == workspaceTodos && viewItem =~ /^todoItem/",
          "group": "todo@2"
        },
        {
          "command": "workspace.moveTodoUp",
          "when": "view == workspaceTodos && viewItem =~ /^todoItem/",
          "group": "todo@3"
        },
        {
          "command": "workspace.moveTodoDown",
          "when": "view == workspaceTodos && viewItem =~ /^todoItem/",
          "group": "todo@4"
        },
        {
          "command": "workspace.openDocumentFileFolder",
          "when": "view == workspaceDocumentFiles && viewItem == docSyncMapping",
          "group": "docFiles@1"
        },
        {
          "command": "nulab.google.openInBrowser",
          "when": "view == workspaceGoogleCalendar && viewItem == calendarEvent",
          "group": "google@1"
        },
        {
          "command": "nulab.google.openInBrowser",
          "when": "view == workspaceGoogleCalendar && viewItem == calendarDocument",
          "group": "google@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "nulab.openProjectByKey",
        "key": "alt+shift+p",
        "mac": "ctrl+shift+p"
      },
      {
        "command": "nulab.openIssueByKey",
        "key": "alt+shift+i",
        "mac": "ctrl+shift+i"
      },
      {
        "command": "workspace.deleteTodo",
