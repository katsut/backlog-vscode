    ],
    "configuration": {
      "title": "Nulab",
      "properties": {
        "nulab.backlog.domain": {
          "type": "string",
          "default": "",
          "description": "Backlog domain (e.g., yourspace.backlog.jp)"
        },
        "nulab.backlog.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Auto refresh project data"
        },
        "nulab.backlog.refreshInterval": {
          "type": "number",
          "default": 300,
          "description": "Auto refresh interval (seconds)"
        },
        "nulab.backlog.favoriteProjects": {
          "type": "array",
          "default": [],
          "description": "お気に入りプロジェクトの projectKey リスト",
          "items": {
            "type": "string"
          }
        },
        "nulab.cacoo.organizationKey": {
          "type": "string",
          "default": "",
          "description": "Cacoo Organization Key"
        },
        "nulab.cacoo.syncMappings": {
          "type": "array",
          "default": [],
          "description": "Cacoo フォルダとローカルディレクトリのマッピング設定",
          "items": {
            "type": "object",
            "required": [
              "localPath",
              "organizationKey",
              "folderId"
            ],
            "properties": {
              "localPath": {
                "type": "string",
                "description": "ワークスペースからの相対パス (例: cacoo-sheets)"
              },
              "organizationKey": {
                "type": "string",
                "description": "Cacoo Organization Key"
              },
              "folderId": {
                "type": "number",
                "description": "Cacoo Folder ID"
              },
              "folderName": {
                "type": "string",
                "description": "フォルダ名 (表示用)"
              }
            },
            "additionalProperties": false
          }
        },
        "nulab.cacoo.pinnedSheets": {
          "type": "array",
          "default": [],
          "description": "ピン留めした Cacoo シート",
          "items": {
            "type": "object",
            "properties": {
              "diagramId": {
                "type": "string"
              },
              "sheetUid": {
                "type": "string"
              },
              "label": {
                "type": "string"
              }
            }
          }
        },
        "nulab.ai.model": {
          "type": "string",
          "default": "claude-sonnet-4-20250514",
          "description": "Anthropic model for AI reply drafts"
        },
        "nulab.backlog.notificationPollingInterval": {
          "type": "number",
          "default": 60,
          "minimum": 15,
          "description": "Backlog 通知のポーリング間隔 (秒)"
        },
        "nulab.slack.pollingInterval": {
          "type": "number",
          "default": 180,
          "minimum": 60,
          "description": "Slack のポーリング間隔 (秒)"
        },
        "nulab.backlog.autoTodoEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Backlog 通知から自動で TODO を作成する"
        },
        "nulab.backlog.autoTodoReasons": {
          "type": "array",
          "default": [1, 2, 9, 10],
          "items": { "type": "number" },
          "description": "自動 TODO 作成の対象 reason (1=assigned, 2=commented, 9=PR, 10=PR commented)"
        },
        "nulab.slack.autoTodoEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Slack メンションから自動で TODO を作成する"
        },
        "nulab.slack.includeDMs": {
          "type": "boolean",
          "default": true,
          "description": "Slack 通知に DM を含める"
        },
        "nulab.slack.autoTodoDMs": {
          "type": "boolean",
          "default": false,
          "description": "DM から自動で TODO を作成する (includeDMs が有効な場合のみ)"
        },
        "nulab.google.clientId": {
          "type": "string",
          "default": "",
          "description": "Google OAuth Client ID"
        },
        "nulab.google.calendarId": {
          "type": "string",
          "default": "primary",
          "description": "取得する Google Calendar ID"
        },
        "nulab.google.daysRange": {
          "type": "number",
          "default": 7,
          "minimum": 1,
          "maximum": 30,
          "description": "表示する日数範囲 (前後)"
        }
      }
    },
    "languages": [
      {
        "id": "bdoc",
        "extensions": [".bdoc"],
        "aliases": ["Backlog Document"],
        "icon": {
          "light": "media/backlog-icon-light.svg",
          "dark": "media/backlog-icon.svg"
        }
      }
    ],
    "customEditors": [
      {
        "viewType": "nulab.bdocEditor",
        "displayName": "Backlog Document Editor",
        "selector": [
          {
            "filenamePattern": "*.bdoc"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "nulab.todoEditor",
        "displayName": "TODO",
        "selector": [
          {
            "filenamePattern": "*.todomd"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",
    "test": "node ./out/test/runTest.js",
    "format": "prettier --write \"src/**/*.ts\"",
    "package": "vsce package",
    "install:local": "npm run compile && vsce package && code --install-extension nulab-vscode-0.0.1.vsix && echo 'Installed! Reload VSCode to apply.'"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "@vscode/test-electron": "^2.2.0",
    "eslint": "^8.28.0",
    "prettier": "^2.8.0",
    "typescript": "^4.9.4",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "@slack/web-api": "^7.14.1",
    "@types/marked": "^5.0.2",
    "backlog-js": "^0.15.0",
    "marked": "^17.0.0"
  }
