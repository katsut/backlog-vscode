{
  "name": "nulab-vscode",
  "displayName": "Nulab Workspace Extension",
  "description": "Backlog, Cacoo, and Slack integration for VS Code",
  "version": "0.0.1",
  "publisher": "katsut",
  "license": "MIT",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "backlog",
    "cacoo",
    "slack",
    "nulab",
    "project management",
    "issue tracking"
  ],
  "activationEvents": [
    "*"
  ],
  "icon": "images/Nulab_icon.png",
  "main": "./out/extension.js",
  "contributes": {
    "colors": [
      {
        "id": "nulab.brandColor",
        "description": "Backlog brand color for tree view icons",
        "defaults": {
          "dark": "#42CE9F",
          "light": "#36B48C",
          "highContrast": "#42CE9F",
          "highContrastLight": "#36B48C"
        }
      },
      {
        "id": "cacoo.brandColor",
        "description": "Cacoo brand color for tree view icons",
        "defaults": {
          "dark": "#00C4CC",
          "light": "#00A8B0",
          "highContrast": "#00C4CC",
          "highContrastLight": "#00A8B0"
        }
      }
    ],
    "views": {
      "backlogContainer": [
        {
          "id": "backlogIssues",
          "name": "Issues",
          "when": "nulabExplorer.enabled && nulabProjectFocused"
        },
        {
          "id": "backlogWiki",
          "name": "Wiki",
          "when": "nulabExplorer.enabled && nulabProjectFocused"
        },
        {
          "id": "backlogDocuments",
          "name": "Documents",
          "when": "nulabExplorer.enabled && nulabProjectFocused"
        }
      ],
      "workspaceContainer": [
        {
          "id": "workspaceMyTasks",
          "name": "Backlog: My Tasks"
        },
        {
          "id": "workspaceTodos",
          "name": "TODO"
        },
        {
          "id": "workspaceDocumentFiles",
          "name": "Backlog: Documents"
        },
        {
          "id": "backlogProjects",
          "name": "Backlog: Projects",
          "when": "nulabExplorer.enabled"
        },
        {
          "id": "cacooDiagrams",
          "name": "Cacoo"
        }
      ],
      "notificationsContainer": [
        {
          "id": "workspaceGoogleCalendar",
          "name": "Google: Calendar"
        },
        {
          "id": "workspaceNotifications",
          "name": "Backlog: Notifications"
        },
        {
          "id": "workspaceSlack",
          "name": "Slack: Notifications"
        },
        {
          "id": "workspaceSlackSearch",
          "name": "Slack: Search"
        },
        {
          "id": "workspaceSlackPost",
          "name": "Slack: Post",
          "type": "webview"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "backlogContainer",
          "title": "Backlog",
          "icon": "media/nulab-icon.svg"
        },
        {
          "id": "workspaceContainer",
          "title": "Workspace",
          "icon": "media/nulab-icon.svg"
        },
        {
          "id": "notificationsContainer",
          "title": "Notifications",
          "icon": "media/nulab-icon.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "backlogProjects",
        "contents": "Configure Backlog settings to get started.\n[Open Settings](command:nulab.openSettings)"
      },
      {
        "view": "cacooDiagrams",
        "contents": "Configure Cacoo API Key to get started.\n[Set Cacoo API Key](command:cacoo.setApiKey)"
      },
      {
        "view": "workspaceMyTasks",
        "contents": "Configure Backlog settings to see your tasks.\n[Open Settings](command:nulab.openSettings)"
      },
      {
        "view": "workspaceSlack",
        "contents": "Slack トークンを設定してメッセージを確認しましょう。\n[Set Slack Token](command:workspace.setSlackToken)",
        "when": "nulab.slack.showWelcome"
      },
      {
        "view": "workspaceSlackSearch",
        "contents": "検索キーワードを追加して、Slack メッセージを監視しましょう。\n[キーワードを設定](command:workspace.editSlackSearchKeywords)",
        "when": "!nulab.slackSearch.hasKeywords"
      },
      {
        "view": "workspaceSlackSearch",
        "contents": "Slack トークンを設定してください。\n[Set Slack Token](command:workspace.setSlackToken)",
        "when": "nulab.slack.showWelcome"
      },
      {
        "view": "workspaceDocumentFiles",
        "contents": "ドキュメント同期マッピングが設定されていません。\n[マッピングを設定](command:nulab.editDocumentSyncMapping)"
      },
      {
        "view": "workspaceGoogleCalendar",
        "contents": "Google アカウントにサインインして会議の議事録を確認しましょう。\n[Sign in to Google](command:nulab.google.authenticate)"
      }
    ],
    "commands": [
      {
        "command": "nulab.treeItemClicked",
        "title": "Open Item (Click)",
        "category": "Nulab"
      },
      {
        "command": "nulab.openSelectedTreeItem",
        "title": "Open Selected Item",
        "category": "Nulab"
      },
      {
        "command": "nulab.google.openSelectedCalendarItem",
        "title": "Open Selected Calendar Item",
        "category": "Nulab"
      },
      {
        "command": "nulab.refreshProjects",
        "title": "Refresh Projects",
        "icon": "$(refresh)",
        "category": "Backlog"
      },
      {
        "command": "nulab.refreshIssues",
        "title": "Refresh Issues",
        "icon": "$(refresh)",
        "category": "Backlog"
      },
      {
        "command": "nulab.refreshWiki",
        "title": "Refresh Wiki",
        "icon": "$(refresh)",
        "category": "Backlog"
      },
      {
        "command": "nulab.refreshDocuments",
        "title": "Refresh Documents",
        "icon": "$(refresh)",
        "category": "Backlog"
      },
      {
        "command": "nulab.filterModifiedDocuments",
        "title": "Filter Modified Documents",
        "icon": "$(filter)",
        "category": "Backlog"
      },
      {
        "command": "nulab.searchProjects",
        "title": "Search Projects",
        "icon": "$(search)",
        "category": "Backlog"
      },
      {
        "command": "nulab.clearProjectSearch",
        "title": "Clear Search",
        "icon": "$(clear-all)",
        "category": "Backlog"
      },
      {
        "command": "nulab.openIssue",
        "title": "Open Issue",
        "category": "Backlog"
      },
      {
        "command": "nulab.openSettings",
        "title": "Open Settings",
        "icon": "$(gear)",
        "category": "Backlog"
      },
      {
        "command": "nulab.setApiKey",
        "title": "Set Backlog API Key",
        "icon": "$(key)",
        "category": "Backlog"
      },
      {
        "command": "nulab.search",
        "title": "Search Issues",
        "icon": "$(search)",
        "category": "Backlog"
      },
      {
        "command": "nulab.filter",
        "title": "Filter Issues",
        "icon": "$(filter)",
        "category": "Backlog"
