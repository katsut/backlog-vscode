{
  "name": "backlog-vscode",
  "displayName": "Backlog Viewer",
  "description": "Backlog viewer and management extension for VS Code",
  "version": "0.0.1",
  "publisher": "backlog-vscode",
  "license": "MIT",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "backlog",
    "cacoo",
    "project management",
    "issue tracking",
    "viewer"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "colors": [
      {
        "id": "backlog.brandColor",
        "description": "Backlog brand color for tree view icons",
        "defaults": {
          "dark": "#42CE9F",
          "light": "#36B48C",
          "highContrast": "#42CE9F",
          "highContrastLight": "#36B48C"
        }
      },
      {
        "id": "cacoo.brandColor",
        "description": "Cacoo brand color for tree view icons",
        "defaults": {
          "dark": "#00C4CC",
          "light": "#00A8B0",
          "highContrast": "#00C4CC",
          "highContrastLight": "#00A8B0"
        }
      }
    ],
    "views": {
      "backlogContainer": [
        {
          "id": "backlogProjects",
          "name": "Projects",
          "when": "!backlogProjectFocused && backlogExplorer.enabled"
        },
        {
          "id": "backlogIssues",
          "name": "Issues",
          "when": "backlogExplorer.enabled && backlogProjectFocused"
        },
        {
          "id": "backlogWiki",
          "name": "Wiki",
          "when": "backlogExplorer.enabled && backlogProjectFocused"
        },
        {
          "id": "backlogDocuments",
          "name": "Documents",
          "when": "backlogExplorer.enabled && backlogProjectFocused"
        }
      ],
      "cacooContainer": [
        {
          "id": "cacooDiagrams",
          "name": "Diagrams"
        }
      ],
      "backlogIssueDetail": [
        {
          "id": "backlogIssueDetailView",
          "name": "Issue Detail",
          "type": "webview"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "backlogContainer",
          "title": "Backlog",
          "icon": "$(project)"
        },
        {
          "id": "cacooContainer",
          "title": "Cacoo",
          "icon": "$(symbol-misc)"
        }
      ],
      "panel": [
        {
          "id": "backlogIssueDetail",
          "title": "Backlog Issue Detail",
          "icon": "$(bug)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "backlogProjects",
        "contents": "Configure Backlog settings to get started.\n[Open Settings](command:backlog.openSettings)"
      },
      {
        "view": "cacooDiagrams",
        "contents": "Configure Cacoo API Key to get started.\n[Set Cacoo API Key](command:cacoo.setApiKey)"
      }
    ],
    "commands": [
      {
        "command": "backlog.refreshProjects",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "backlog.refreshIssues",
        "title": "Refresh Issues",
        "icon": "$(refresh)"
      },
      {
        "command": "backlog.refreshWiki",
        "title": "Refresh Wiki",
        "icon": "$(refresh)"
      },
      {
        "command": "backlog.refreshDocuments",
        "title": "Refresh Documents",
        "icon": "$(refresh)"
      },
      {
        "command": "backlog.searchProjects",
        "title": "Search Projects",
        "icon": "$(search)"
      },
      {
        "command": "backlog.clearProjectSearch",
        "title": "Clear Search",
        "icon": "$(clear-all)"
      },
      {
        "command": "backlog.openIssue",
        "title": "Open Issue"
      },
      {
        "command": "backlog.openSettings",
        "title": "Open Settings",
        "icon": "$(gear)",
        "category": "Backlog"
      },
      {
        "command": "backlog.setApiKey",
        "title": "Set API Key",
        "icon": "$(key)"
      },
      {
        "command": "backlog.search",
        "title": "Search Issues",
        "icon": "$(search)"
      },
      {
        "command": "backlog.filter",
        "title": "Filter Issues",
        "icon": "$(filter)"
      },
      {
        "command": "backlog.sort",
        "title": "Sort Issues",
        "icon": "$(sort-precedence)"
      },
      {
        "command": "backlog.clearFilters",
        "title": "Clear Filters",
        "icon": "$(clear-all)"
      },
      {
        "command": "backlog.focusProject",
        "title": "Focus Project"
      },
      {
        "command": "backlog.unfocusProject",
        "title": "Back to Projects",
        "icon": "$(arrow-left)"
      },
      {
        "command": "backlog.openWiki",
        "title": "Open Wiki"
      },
      {
        "command": "backlog.openDocument",
        "title": "Open Document"
      },
      {
        "command": "backlog.openProjectByKey",
        "title": "Open Project by Key",
        "category": "Backlog"
      },
      {
        "command": "backlog.openIssueByKey",
        "title": "Open Issue by Key",
        "category": "Backlog"
      },
      {
        "command": "backlog.setDocumentSyncMapping",
        "title": "Set Document Sync Mapping",
        "icon": "$(link)"
      },
      {
        "command": "backlog.documentSync.pull",
        "title": "Pull Documents from Backlog",
        "icon": "$(cloud-download)",
        "category": "Backlog"
      },
      {
        "command": "backlog.documentSync.status",
        "title": "Show Document Sync Status",
        "icon": "$(sync)",
        "category": "Backlog"
      },
      {
        "command": "backlog.documentSync.diff",
        "title": "Diff with Remote Backlog Document",
        "icon": "$(diff)",
        "category": "Backlog"
      },
      {
        "command": "backlog.documentSync.copyAndOpen",
        "title": "Copy to Clipboard & Open in Backlog",
        "icon": "$(link-external)",
        "category": "Backlog"
      },
      {
        "command": "backlog.documentSync.push",
        "title": "Push New Document to Backlog",
        "icon": "$(cloud-upload)",
        "category": "Backlog"
      },
      {
        "command": "backlog.toggleFavorite",
        "title": "Toggle Favorite",
        "icon": "$(star)"
      },
      {
        "command": "backlog.editDocumentSyncMapping",
        "title": "Edit Document Sync Mappings",
        "icon": "$(settings-gear)",
        "category": "Backlog"
      },
      {
        "command": "backlog.documentSync.edit",
        "title": "Open in Document Editor",
        "icon": "$(edit)",
        "category": "Backlog"
      },
      {
        "command": "cacoo.refreshDiagrams",
        "title": "Refresh Diagrams",
        "icon": "$(refresh)",
        "category": "Cacoo"
      },
      {
        "command": "cacoo.setApiKey",
        "title": "Set Cacoo API Key",
        "icon": "$(key)",
        "category": "Cacoo"
      },
      {
        "command": "cacoo.previewSheet",
        "title": "Preview Sheet",
        "icon": "$(open-preview)",
        "category": "Cacoo"
      },
      {
        "command": "cacoo.openInBrowser",
        "title": "Open in Cacoo",
        "icon": "$(link-external)",
        "category": "Cacoo"
      },
      {
        "command": "cacoo.togglePin",
        "title": "Toggle Pin",
        "icon": "$(pin)",
        "category": "Cacoo"
      },
      {
        "command": "cacoo.pull",
        "title": "Pull Sheet Images",
        "icon": "$(cloud-download)",
        "category": "Cacoo"
      },
      {
        "command": "cacoo.setSyncMapping",
        "title": "Set Cacoo Sync Mapping",
        "icon": "$(link)",
        "category": "Cacoo"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "backlog.refreshProjects",
          "when": "view == backlogProjects",
          "group": "navigation@1"
        },
        {
          "command": "backlog.searchProjects",
          "when": "view == backlogProjects",
          "group": "navigation@2"
        },
        {
          "command": "backlog.clearProjectSearch",
          "when": "view == backlogProjects",
          "group": "navigation@3"
        },
        {
          "command": "backlog.openSettings",
          "when": "view == backlogProjects",
          "group": "navigation@4"
        },
        {
          "command": "backlog.refreshIssues",
          "when": "view == backlogIssues",
          "group": "navigation@1"
        },
        {
          "command": "backlog.search",
          "when": "view == backlogIssues",
          "group": "navigation@2"
        },
        {
          "command": "backlog.filter",
          "when": "view == backlogIssues",
          "group": "navigation@3"
        },
        {
          "command": "backlog.sort",
          "when": "view == backlogIssues",
          "group": "navigation@4"
        },
        {
          "command": "backlog.clearFilters",
          "when": "view == backlogIssues",
          "group": "navigation@5"
        },
        {
          "command": "backlog.unfocusProject",
          "when": "view == backlogIssues",
          "group": "navigation@6"
        },
        {
          "command": "backlog.refreshWiki",
          "when": "view == backlogWiki",
          "group": "navigation@1"
        },
        {
          "command": "backlog.unfocusProject",
          "when": "view == backlogWiki",
          "group": "navigation@2"
        },
        {
          "command": "backlog.refreshDocuments",
          "when": "view == backlogDocuments",
          "group": "navigation@1"
        },
        {
          "command": "backlog.unfocusProject",
          "when": "view == backlogDocuments",
          "group": "navigation@2"
        },
        {
          "command": "cacoo.refreshDiagrams",
          "when": "view == cacooDiagrams",
          "group": "navigation@1"
        },
        {
          "command": "cacoo.pull",
          "when": "view == cacooDiagrams",
          "group": "navigation@2"
        },
        {
          "command": "cacoo.setApiKey",
          "when": "view == cacooDiagrams",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "backlog.toggleFavorite",
          "when": "view == backlogProjects && viewItem =~ /^(project|favoriteProject)$/",
          "group": "favorites@1"
        },
        {
          "command": "backlog.setDocumentSyncMapping",
          "when": "view == backlogDocuments && viewItem =~ /^(documentFolder|documentWithChildren)$/",
          "group": "sync@1"
        },
        {
          "command": "backlog.documentSync.pull",
          "when": "view == backlogDocuments && viewItem =~ /^(documentFolder|documentWithChildren)$/",
          "group": "sync@2"
        },
        {
          "command": "backlog.documentSync.diff",
          "when": "view == backlogDocuments && viewItem == document",
          "group": "sync@3"
        },
        {
          "command": "backlog.documentSync.copyAndOpen",
          "when": "view == backlogDocuments && viewItem == document",
          "group": "sync@4"
        },
        {
          "command": "cacoo.togglePin",
          "when": "view == cacooDiagrams && viewItem == cacooSheet",
          "group": "pin@1"
        },
        {
          "command": "cacoo.openInBrowser",
          "when": "view == cacooDiagrams && viewItem =~ /^(cacooDiagram|cacooSheet)$/",
          "group": "navigation@1"
        },
        {
          "command": "cacoo.setSyncMapping",
          "when": "view == cacooDiagrams && viewItem == cacooFolder",
          "group": "sync@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "backlog.openProjectByKey",
        "key": "alt+shift+p",
        "mac": "ctrl+shift+p"
      },
      {
        "command": "backlog.openIssueByKey",
        "key": "alt+shift+i",
        "mac": "ctrl+shift+i"
      }
    ],
    "configuration": {
      "title": "Backlog",
      "properties": {
        "backlog.domain": {
          "type": "string",
          "default": "",
          "description": "Backlog domain (e.g., yourspace.backlog.jp)"
        },
        "backlog.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Auto refresh project data"
        },
        "backlog.refreshInterval": {
          "type": "number",
          "default": 300,
          "description": "Auto refresh interval (seconds)"
        },
        "backlog.favoriteProjects": {
          "type": "array",
          "default": [],
          "description": "お気に入りプロジェクトの projectKey リスト",
          "items": {
            "type": "string"
          }
        },
        "backlog.documentSync.mappings": {
          "type": "array",
          "default": [],
          "description": "Backlog ドキュメントとローカルディレクトリのマッピング設定",
          "items": {
            "type": "object",
            "required": ["localPath", "projectKey", "documentNodeId"],
            "properties": {
              "localPath": {
                "type": "string",
                "description": "ワークスペースからの相対パス (例: docs/design)"
              },
              "projectKey": {
                "type": "string",
                "description": "Backlog プロジェクトキー (例: BNN)"
              },
              "documentNodeId": {
                "type": "string",
                "description": "マッピング先の Backlog ドキュメントノード ID"
              },
              "documentNodeName": {
                "type": "string",
                "description": "ドキュメントノード名 (表示用、自動設定)"
              }
            },
            "additionalProperties": false
          }
        },
        "backlog.cacoo.organizationKey": {
          "type": "string",
          "default": "",
          "description": "Cacoo Organization Key"
        },
        "backlog.cacoo.syncMappings": {
          "type": "array",
          "default": [],
          "description": "Cacoo フォルダとローカルディレクトリのマッピング設定",
          "items": {
            "type": "object",
            "required": ["localPath", "organizationKey", "folderId"],
            "properties": {
              "localPath": {
                "type": "string",
                "description": "ワークスペースからの相対パス (例: cacoo-sheets)"
              },
              "organizationKey": {
                "type": "string",
                "description": "Cacoo Organization Key"
              },
              "folderId": {
                "type": "number",
                "description": "Cacoo Folder ID"
              },
              "folderName": {
                "type": "string",
                "description": "フォルダ名 (表示用)"
              }
            },
            "additionalProperties": false
          }
        },
        "backlog.cacoo.pinnedSheets": {
          "type": "array",
          "default": [],
          "description": "ピン留めした Cacoo シート",
          "items": {
            "type": "object",
            "properties": {
              "diagramId": { "type": "string" },
              "sheetUid": { "type": "string" },
              "label": { "type": "string" }
            }
          }
        }
      }
    },
    "customEditors": [
      {
        "viewType": "backlog.bdocEditor",
        "displayName": "Backlog Document Editor",
        "selector": [
          {
            "filenamePattern": "*.bdoc"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",
    "test": "node ./out/test/runTest.js",
    "format": "prettier --write \"src/**/*.ts\"",
    "package": "vsce package",
    "install:local": "npm run compile && vsce package && code --install-extension backlog-vscode-0.0.1.vsix && echo 'Installed! Reload VSCode to apply.'"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "@vscode/test-electron": "^2.2.0",
    "eslint": "^8.28.0",
    "prettier": "^2.8.0",
    "typescript": "^4.9.4",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "@types/marked": "^5.0.2",
    "backlog-js": "^0.15.0",
    "marked": "^17.0.0"
  }
}
