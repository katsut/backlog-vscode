        "title": "Back to Projects",
        "icon": "$(arrow-left)",
        "category": "Backlog"
      },
      {
        "command": "nulab.openWiki",
        "title": "Open Wiki",
        "category": "Backlog"
      },
      {
        "command": "nulab.openDocument",
        "title": "Open Document",
        "category": "Backlog"
      },
      {
        "command": "nulab.openProjectByKey",
        "title": "Open Project by Key",
        "category": "Backlog"
      },
      {
        "command": "nulab.openIssueByKey",
        "title": "Open Issue by Key",
        "category": "Backlog"
      },
      {
