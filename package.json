      {
        "command": "cacoo.togglePin",
        "title": "Toggle Pin",
        "icon": "$(pin)",
        "category": "Cacoo"
      },
      {
        "command": "cacoo.pull",
        "title": "Pull Sheet Images",
        "icon": "$(cloud-download)",
        "category": "Cacoo"
      },
      {
        "command": "cacoo.setSyncMapping",
