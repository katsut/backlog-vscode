        "icon": "$(add)",
        "category": "Backlog"
      },
      {
        "command": "workspace.setSlackToken",
        "title": "Set Slack Token",
        "icon": "$(key)",
        "category": "Slack"
      },
      {
        "command": "workspace.refreshSlack",
        "title": "Refresh Messages",
        "icon": "$(refresh)",
        "category": "Slack"
      },
      {
        "command": "workspace.refreshSlackSearch",
        "title": "Refresh Search",
        "icon": "$(refresh)",
        "category": "Slack"
      },
      {
        "command": "workspace.refreshDocumentFiles",
