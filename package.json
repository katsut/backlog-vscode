        "when": "view == backlogDocuments && listFocus"
      },
      {
        "command": "nulab.openSelectedTreeItem",
        "key": "enter",
        "mac": "enter",
        "when": "view == workspaceTodos && listFocus"
      },
      {
        "command": "nulab.openSelectedTreeItem",
        "key": "enter",
        "mac": "enter",
        "when": "view == workspaceMyTasks && listFocus"
      },
      {
        "command": "nulab.openSelectedTreeItem",
        "key": "enter",
        "mac": "enter",
        "when": "view == workspaceNotifications && listFocus"
      },
      {
        "command": "nulab.openSelectedTreeItem",
        "key": "enter",
        "mac": "enter",
        "when": "view == cacooDiagrams && listFocus"
      },
      {
        "command": "nulab.openSelectedTreeItem",
        "key": "enter",
        "mac": "enter",
        "when": "view == workspaceDocumentFiles && listFocus"
      },
      {
        "command": "nulab.openSelectedTreeItem",
        "key": "enter",
